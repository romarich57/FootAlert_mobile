{
  "name": "@footalert/app-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./security/requestSignaturePayload": {
      "types": "./dist/security/requestSignaturePayload.d.ts",
      "import": "./dist/security/requestSignaturePayload.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "npm run build",
    "test": "node --test test/**/*.test.mjs",
    "test:contract-runtime": "npm run build && node --test test/runtime/**/*.test.mjs test/services/**/*.test.mjs"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
