APP_ENV=production
PORT=3001
HOST=0.0.0.0
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=your_production_server_side_api_football_key
API_TIMEOUT_MS=10000
API_MAX_RETRIES=2
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
TRUST_PROXY_HOPS=1
CORS_ALLOWED_ORIGINS=https://footalert.romdev.cloud
WEB_APP_ORIGIN=https://footalert.romdev.cloud
CACHE_MAX_ENTRIES=1000
CACHE_CLEANUP_INTERVAL_MS=60000
CACHE_BACKEND=redis
CACHE_STRICT_MODE=true
REDIS_URL=redis://your-prod-redis:6379/0
REDIS_CACHE_PREFIX=footalert:bff:
BFF_EXPOSE_ERROR_DETAILS=false
MOBILE_SESSION_JWT_SECRET=change_me_mobile_session_secret
MOBILE_SESSION_TOKEN_TTL_MS=900000
MOBILE_REFRESH_TOKEN_TTL_MS=2592000000
MOBILE_AUTH_CHALLENGE_TTL_MS=120000
MOBILE_ATTESTATION_ACCEPT_MOCK=false
MOBILE_ATTESTATION_ENFORCEMENT_MODE=strict
MOBILE_AUTH_ENFORCED_HOSTS=api.footalert.romdev.cloud
MOBILE_PLAY_INTEGRITY_PACKAGE_NAME=com.footalert.app
MOBILE_PLAY_INTEGRITY_SERVICE_ACCOUNT_EMAIL=
MOBILE_PLAY_INTEGRITY_SERVICE_ACCOUNT_PRIVATE_KEY=
MOBILE_APP_ATTEST_BUNDLE_ID=com.footalert.app
MOBILE_APP_ATTEST_TEAM_ID=
MOBILE_APP_ATTEST_VERIFICATION_URL=
MOBILE_APP_ATTEST_VERIFICATION_SECRET=
PAGINATION_CURSOR_SECRET=
PAGINATION_CURSOR_TTL_MS=900000
NOTIFICATIONS_BACKEND_ENABLED=true
NOTIFICATIONS_EVENT_INGEST_ENABLED=true
NOTIFICATIONS_PERSISTENCE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/footalert
NOTIFICATIONS_INGEST_TOKEN=change_me_notifications_ingest_token
PUSH_TOKEN_ENCRYPTION_KEY=change_me_push_token_encryption_key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
