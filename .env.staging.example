APP_ENV=staging
MOBILE_API_BASE_URL=https://your-staging-domain/v1
WEB_API_BASE_URL=https://your-staging-domain/v1
DESKTOP_API_BASE_URL=https://your-staging-domain/v1
WEB_APP_ORIGIN=https://staging.your-domain
MOBILE_AUTH_ATTESTATION_MODE=provider
MOBILE_ATTESTATION_STRATEGY=strict
MOBILE_SESSION_TOKEN_TTL_MS=600000
MOBILE_PINNING_ENABLED=true
MOBILE_PINNING_HOST=your-staging-domain
MOBILE_PINNING_SPKI_PRIMARY=sha256/your_primary_pin
MOBILE_PINNING_SPKI_BACKUP=sha256/your_backup_pin
MOBILE_PINNING_KILL_SWITCH_ALLOW=false
ASSET_CDN_REWRITE_ENABLED=false
ASSET_CDN_BASE_URL=https://assets.your-staging-domain
MOBILE_PRIVACY_POLICY_URL=https://your-staging-domain/legal/privacy
MOBILE_TERMS_OF_USE_URL=https://your-staging-domain/legal/terms
MOBILE_SUPPORT_URL=https://your-staging-domain/support
MOBILE_FOLLOW_US_URL=https://your-staging-domain/social
MOBILE_APP_STORE_URL=https://apps.apple.com/app/id0000000000
MOBILE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.footalert.app
MOBILE_PUSH_TOKEN=
MATCHES_QUERY_STALE_TIME_MS=60000
MATCHES_LIVE_REFRESH_INTERVAL_MS=120000
MATCHES_SLOW_REFRESH_INTERVAL_MS=120000
MATCHES_MAX_REFRESH_BACKOFF_MS=120000
MATCHES_BATTERY_SAVER_REFRESH_INTERVAL_MS=120000
FOLLOWS_SEARCH_DEBOUNCE_MS=500
FOLLOWS_SEARCH_MIN_CHARS=2
FOLLOWS_SEARCH_RESULTS_LIMIT=20
FOLLOWS_TEAM_NEXT_FIXTURE_TTL_MS=3600000
FOLLOWS_PLAYER_STATS_TTL_MS=3600000
FOLLOWS_TRENDS_TTL_MS=21600000
FOLLOWS_TRENDS_LEAGUE_COUNT=7
FOLLOWS_TRENDS_TEAMS_LIMIT=8
FOLLOWS_TRENDS_PLAYERS_LIMIT=8
FOLLOWS_MAX_FOLLOWED_TEAMS=30
FOLLOWS_MAX_FOLLOWED_PLAYERS=30
FOLLOWS_MAX_FOLLOWED_LEAGUES=30
MOBILE_ENABLE_BFF_PLAYER_AGGREGATES=true
NOTIFICATIONS_MATCH_BACKEND_ENABLED=true
MOBILE_ENABLE_STORYBOOK=false
