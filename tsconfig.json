{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": [
      "jest"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@data/*": [
        "src/data/*"
      ],
      "@ui/*": [
        "src/ui/*"
      ],
      "@domain/*": [
        "src/domain/*"
      ],
      "@app-core": [
        "packages/app-core/src/index"
      ],
      "@app-core/*": [
        "packages/app-core/src/*"
      ],
      "@api-contract": [
        "packages/api-contract/generated/types"
      ],
      "@api-contract/*": [
        "packages/api-contract/generated/*"
      ]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods",
    "footalert-bff/**",
    "web/**",
    "desktop/**",
    "site_vitrine/**",
    "packages/api-contract/**"
  ]
}
